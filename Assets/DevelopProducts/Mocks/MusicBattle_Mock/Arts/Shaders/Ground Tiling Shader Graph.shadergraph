    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "WorldTriplanar",
    "m_FunctionSource": "e600e922b67c01c4d8f2f67b91db146f",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "void WorldTriplanar_float(\r\n    float3 worldPos,\r\n    float3 worldNormal,\r\n    float tileSize,\r\n    sampler2D tex,\r\n    out float4 color\r\n)\r\n{\r\n    float3 n = normalize(worldNormal);\r\n\r\n    float2 uvX = worldPos.yz / tileSize;\r\n    float2 uvY = worldPos.xz / tileSize;\r\n    float2 uvZ = worldPos.xy / tileSize;\r\n\r\n    float4 cx = tex2D(tex, uvX);\r\n    float4 cy = tex2D(tex, uvY);\r\n    float4 cz = tex2D(tex, uvZ);\r\n\r\n    float3 blend = abs(n);\r\n    blend = blend / (blend.x + blend.y + blend.z + 1e-5);\r\n\r\n    color = cx * blend.x + cy * blend.y + cz * blend.z;\r\n}\r\n"
}

