{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "5fab1684c5e943fca4d900aaee70918e",
    "m_Group": {
        "m_Id": "b727c5077db64a589a2f356e3a862887"
    },
    "m_Name": "PerspectiveChange (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -74.00006866455078,
            "y": -602.0,
            "width": 265.0000305175781,
            "height": 118.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "14d675f0da2e4c1e885a277b023509ba"
        },
        {
            "m_Id": "f572fc07c4974cbfaebec14673f62aaf"
        },
        {
            "m_Id": "9c437bc7c3dd4163aed8ec2d28ce496b"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "PerspectiveChange",
    "m_FunctionSource": "40bb4f17a3f8f92449de043877648e43",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "float4 positionCS = TransformObjectToHClip(Position);\n\n// 透視投影のNDC\nfloat2 perspNDC = positionCS.xy / positionCS.w;\n\n// 正投影相当のNDC（オブジェクトのピボット深度を基準にスケール）\nfloat3 pivotVS = TransformWorldToView(TransformObjectToWorld(float3(0, 0, 0)));\nfloat2 orthoNDC = perspNDC * (positionCS.w / abs(pivotVS.z));\n\n// NDC空間でブレンド\nfloat2 blendedNDC = lerp(orthoNDC, perspNDC, PerspectiveAmount);\n\n// 元のwを使ってClip空間に戻す（深度は保持）\nfloat4 blendedCS = float4(blendedNDC * positionCS.w, positionCS.zw);\n\n// Object空間に逆変換\nfloat3 ndc = blendedCS.xyz / blendedCS.w;\nfloat4 worldPos = mul(UNITY_MATRIX_I_VP, float4(ndc, 1.0));\nworldPos /= worldPos.w;\nOut = mul(UNITY_MATRIX_I_M, worldPos).xyz;"
}

