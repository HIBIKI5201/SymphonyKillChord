<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement style="height: 20px; width: 100px; align-items: center; justify-content: center; background-color: rgba(38, 38, 38, 0.5); border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px;">
        <ui:Label text="123456789.0" name="text" style="-unity-text-align: middle-center; color: rgb(255, 255, 255);" />
    </ui:VisualElement>
</ui:UXML>
